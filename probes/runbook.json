{
  "mcp_servers": {
    "local": {
      "transport": "stdio",
      "command": ["python3", "scripts/mcp_mock_stdio.py"]
    }
  },
  "probes": {
    "check_health": {
      "kind": "command",
      "command": ["python3", "scripts/runbook_check_health.py"]
    },
    "log": {
      "kind": "jsonl"
    },
    "notify": {
      "kind": "mcp",
      "server": "local",
      "tool": "notify"
    }
  }
}
