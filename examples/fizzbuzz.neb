sector math {
  fn fizzbuzz(n: Int) -> Str {
    if n mod 15 eq 0 then
      return "fizzbuzz";
    else
      if n mod 3 eq 0 then
        return "fizz";
      else
        if n mod 5 eq 0 then
          return "buzz";
        else
          return int_to_str(n);
        end
      end
    end
  }
}

mission main {
  let mut i: Int = 1;

  while i le 20 do
    print(math.fizzbuzz(i));
    set i = i plus 1;
  end
}